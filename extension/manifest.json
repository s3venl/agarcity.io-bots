{
    "manifest_version": 3,
    "name": "AgarCity.io Bots",
    "version": "1.0.0",
    "description": "A browser extension for enhancing the AgarCity.io gaming experience.",
    "content_scripts": [
        {
            "matches": [
                "*://agarcity.io/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "css/index.css"
            ],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "icons": {
        "128": "icons/icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icons/*",
                "js/*",
                "css/*"
            ],
            "matches": [
                "<all_urls>"
            ],
            "use_dynamic_url": true
        }
    ]
}